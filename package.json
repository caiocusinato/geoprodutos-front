{
  "name": "geoprodutos",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo: geoprodutos-front (Vite/React) + geoprodutos-back (Express/MySQL)",
  "scripts": {
    "dev:front": "npm --prefix geoprodutos-front run dev",
    "build:front": "npm --prefix geoprodutos-front run build",
    "preview:front": "npm --prefix geoprodutos-front run preview",
    "lint:front": "npm --prefix geoprodutos-front run lint",

    "start:back": "npm --prefix geoprodutos-back run start",
    "dev:back": "npm --prefix geoprodutos-back run dev",
    "install:all": "npm --prefix geoprodutos-back install && npm --prefix geoprodutos-front install"
  }
}
